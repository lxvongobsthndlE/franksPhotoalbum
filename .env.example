# ----------------------------
# General
# ----------------------------
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://photoalbum:changeme@db:5432/photoalbum
JWT_SECRET=min-32-zeichen-langer-geheimer-schluessel

# ----------------------------
# Postgres
# ----------------------------
POSTGRES_DB=photoalbum
POSTGRES_USER=photoalbum
POSTGRES_PASSWORD=changeme

# ----------------------------
# MinIO
# ----------------------------
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_strong_password
MINIO_BUCKET_PHOTOS=photos
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_BACKUPS=backups

# ----------------------------
# Authentik / OIDC
# ----------------------------
OIDC_ISSUER=https://auth.example.tld/application/o/photoalbum/
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_REDIRECT_URI_PROD=https://photoalbum.example.tld/auth/callback
OIDC_REDIRECT_URI_DEV=https://photoalbum-dev.example.tld/auth/callback

# ----------------------------
# SMTP / Email (Notifications)
# ----------------------------
SMTP_HOST=https://smtp.example.tld
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@example.tld
SMTP_PASS=your_smtp_password
SMTP_FROM=Franks Fotoalbum
# Optionaler Catch-All für E-Mails im DEV-Modus (nur wenn NODE_ENV != production).
# Nicht gesetzt oder leer: kein Versand.
# Mit fixer Adresse: alle Mails gehen an diese eine Adresse.
#   DEV_MAIL_CATCHALL=dev@example.de
# Mit Platzhalter ${local}: lokaler Teil der Original-Adresse wird eingefügt.
#   DEV_MAIL_CATCHALL=${local}-dev@catchall.example.de
DEV_MAIL_CATCHALL=