// Prisma Schema
// Database schema for Fotoalbum App

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  name      String?
  color     String?
  avatar    String?
  displayNameField String? @default("name") // "name" oder "username"
  role      String   @default("user") // "user" oder "admin"
  migratedFrom String?
  migratedAt DateTime?
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  auth_source String? // "authentik", "google", "plex", "github" etc.

  groups             GroupMember[]
  photos             Photo[]
  comments           Comment[]
  likes              Like[]
  albumContributions AlbumContributor[]
  groupDeputies      GroupDeputy[]
  notifications      Notification[]
    notifPreference    NotificationPreference?
    feedbackReports    FeedbackReport[]
    reportedInFeedback FeedbackReport[] @relation("ReportedUser")
  feedbackMessages   FeedbackMessage[]
}

model Group {
  id                          String   @id @default(cuid())
  name                        String
  code                        String   @unique
  createdBy                   String?
  inviteCodeVisibleToMembers  Boolean  @default(true)
  maxMembers                  Int?
  memberLimitLocked           Boolean  @default(false)
  createdAt                   DateTime @default(now())
  
  members   GroupMember[]
  albums    Album[]
  photos    Photo[]
  deputies  GroupDeputy[]
}

model GroupMember {
  userId String
  groupId String
  
  user   User   @relation(fields: [userId], references: [id])
  group  Group  @relation(fields: [groupId], references: [id])
  
  @@id([userId, groupId])
}

model Album {
  id        String   @id @default(cuid())
  name      String
  groupId   String
  createdBy String
  createdAt DateTime @default(now())
  
  group        Group              @relation(fields: [groupId], references: [id])
  photos       PhotoAlbum[]
  contributors AlbumContributor[]
}

model AlbumContributor {
  albumId String
  userId  String

  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([albumId, userId])
}

model Photo {
  id          String   @id @default(cuid())
  uploaderId  String
  groupId     String
  filename    String
  path        String   @unique
  description String?
  createdAt   DateTime @default(now())
  
  uploader    User         @relation(fields: [uploaderId], references: [id])
  group       Group        @relation(fields: [groupId], references: [id])
  albums      PhotoAlbum[]
  comments    Comment[]
  likes       Like[]
}

model PhotoAlbum {
  photoId String
  albumId String

  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@id([photoId, albumId])
}

model Comment {
  id        String   @id @default(cuid())
  photoId   String
  userId    String
  content   String
  createdAt DateTime @default(now())
  
  photo     Photo    @relation(fields: [photoId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Like {
  id        String   @id @default(cuid())
  photoId   String
  userId    String
  createdAt DateTime @default(now())
  
  photo     Photo    @relation(fields: [photoId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  
  @@unique([photoId, userId])
}

model GroupDeputy {
  groupId String
  userId  String

  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model GroupBackup {
  id            String   @id @default(cuid())
  zipKey        String   @unique
  groupId       String?
  groupName     String
  deletedByName String?
  photoCount    Int      @default(0)
  sizeBytes     BigInt?
  createdAt     DateTime @default(now())
  linkExpiry    DateTime

  @@map("group_backups")
}

model ChangelogEntry {
  id           String   @id @default(cuid())
  version      String
  title        String
  body         String?
  createdById  String?  @map("created_by_id")
  createdByName String? @map("created_by_name")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("changelog_entries")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // deputyAdded | deputyRemoved | contributorAdded | contributorRemoved | groupMemberJoined | groupMemberLeft | groupDeleted | photoLiked | photoCommented | newPhoto | newAlbum
  title       String
  body        String
  entityId    String?  // ID des betroffenen Objekts (Photo, Group, Album...)
  entityType  String?  // "group" | "photo" | "album" | "external"
  imageUrl    String?  // Optionale Bild-URL für Vorschau in der Benachrichtigung
  entityUrl   String?  // Optionale externe URL für Navigation
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

model NotificationPreference {
  userId String @id

  // In-App Einstellungen
  inApp_deputyAdded          Boolean @default(true)
  inApp_deputyRemoved        Boolean @default(true)
  inApp_contributorAdded     Boolean @default(true)
  inApp_contributorRemoved   Boolean @default(true)
  inApp_groupMemberJoined    Boolean @default(true)
  inApp_groupMemberLeft      Boolean @default(true)
  inApp_groupDeleted         Boolean @default(true)
  inApp_photoLiked           Boolean @default(true)
  inApp_photoCommented       Boolean @default(true)
  inApp_newPhoto             Boolean @default(true)
  inApp_newAlbum             Boolean @default(true)
  inApp_system               Boolean @default(true)

  // E-Mail Einstellungen
  email_deputyAdded          Boolean @default(true)
  email_deputyRemoved        Boolean @default(false)
  email_contributorAdded     Boolean @default(true)
  email_contributorRemoved   Boolean @default(false)
  email_groupMemberJoined    Boolean @default(false)
  email_groupMemberLeft      Boolean @default(false)
  email_groupDeleted         Boolean @default(true)
  email_photoLiked           Boolean @default(false)
  email_photoCommented       Boolean @default(false)
  email_newPhoto             Boolean @default(false)
  email_newAlbum             Boolean @default(false)
  email_system               Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackReport {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       String   // "bug" | "feature" | "help" | "report_user" | "other"
  subject        String
  body           String
  anonymous      Boolean  @default(false)
  reportedUserId String?
  reportedUser   User?    @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  status         String   @default("open") // "open" | "closed"
  waitingFor     String   @default("support") // "support" | "user" | "none"
  unreadAdmin    Boolean  @default(true)
  unreadUser     Boolean  @default(false)
  resolution     String?  // "no_action" | "action_taken" — nur für report_user
  createdAt      DateTime @default(now())

  messages  FeedbackMessage[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("feedback_reports")
}

model FeedbackMessage {
  id        String         @id @default(cuid())
  reportId  String
  report    FeedbackReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime       @default(now())

  @@index([reportId])
  @@map("feedback_messages")
}
