{
  "name": "fotoalbum-backend",
  "version": "1.0.0-beta.1",
  "description": "Fotoalbum Fastify Backend",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env.local src/app.js",
    "dev": "node scripts/dev-with-minio.mjs",
    "dev:app": "node --env-file=.env.local --watch src/app.js",
    "prisma:migrate:dev": "node --env-file=.env.local ./node_modules/prisma/build/index.js migrate dev",
    "prisma:generate": "node --env-file=.env.local ./node_modules/prisma/build/index.js generate",
    "generate:infocards": "node scripts/generate-infocards.mjs",
    "migrate": "node --env-file=.env.local db/migrate.js",
    "migrate:supabase": "node --env-file=.env.local scripts/migrate-supabase-to-prisma.mjs",
    "crawl:supabase:anon": "node --env-file=.env.local scripts/crawl-supabase-anon.mjs",
    "crawl:supabase:login": "node --env-file=.env.local scripts/crawl-supabase-login.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format:check && npm run lint && npx prisma validate"
  },
  "dependencies": {
    "@fastify/cookie": "^8.3.0",
    "@fastify/cors": "^8.4.0",
    "@fastify/jwt": "^7.2.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/static": "^6.12.0",
    "@prisma/client": "^5.7.0",
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "bcrypt": "^5.1.0",
    "cookie": "^1.1.1",
    "dotenv": "^16.3.0",
    "fastify": "^4.25.0",
    "jwt-decode": "^4.0.0",
    "minio": "^8.0.7",
    "nodemailer": "^8.0.5",
    "openid-client": "^6.8.3",
    "pg": "^8.11.0",
    "prisma": "^5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^9.0.0",
    "eslint-plugin-jsdoc": "^48.0.0",
    "nodemon": "^3.0.0",
    "pino-pretty": "^10.2.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "vitest": "^1.6.1"
  }
}
